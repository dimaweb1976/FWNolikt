Dim UserCredintials(2) As String

Sub Main
  Dim oSheet As Object

  DataBaseName = &quot;&quot; 

  oFunction = createUnoService(&quot;com.sun.star.sheet.FunctionAccess&quot;)
  Range = thisComponent.getCurrentSelection.getRangeAddress

  &apos; Reading user credintials from Sheet1.A1, Sheet1.A2
  oSheet = ThisComponent.getSheets().getByIndex(0)
  
  UserCredintials(0) = oSheet.GetCellByPosition(0, 0).String
  UserCredintials(1) = oSheet.GetCellByPosition(0, 1).String
  UserCredintials(2) = oSheet.GetCellByPosition(0, 2).String
  DataBaseName = UserCredintials(2) 

  ConnectToDBMark:
 
  If ( (UserCredintials(0) = &quot;&quot; and UserCredintials(1) = &quot;&quot;) or UserCredintials(2) = &quot;&quot;) Then
    GoTo GetUserCredintialsMark 
  End If
 
  On Error GoTo DBErrorHandlingMark  
    Db = connect_to_database(DataBaseName, UserCredintials(0), UserCredintials(1))
    AutoCommit = Db.GetAutoCommit()
    AutoCommit = false
    Db.SetAutoCommit(AutoCommit)
    Statement = db.createStatement
    Statement.ResultSetType = com.sun.star.sdbc.ResultSetType.SCROLL_INSENSITIVE
    
  On Error GoTo DefaultErrorHandlingMark
    StartDialog()

    CloseDialog
    Disconnect_from_database(Db)
  Exit Sub
  
  DBErrorHandlingMark:
    MsgBox &quot;Ошибка подключения к базе данных, проверьте имя пользователя и пароль&quot; &amp; chr(10) &amp; _
           &quot;Error &quot; &amp; Err &amp; &quot;: &quot; &amp; Error$ &amp; &quot; (line : &quot; &amp; Erl &amp; &quot;)&quot;
    Resume GetUserCredintialsMark
    
  GetUserCredintialsMark:
    If InitializeDlgUserCredintials(UserCredintials()) Then    
      GoTo ConnectToDBMark
    Else
      Exit Sub
    End If    
    
  DefaultErrorHandlingMark:
    MsgBox &quot;Error &quot; &amp; Err &amp; &quot;: &quot; &amp; Error$ &amp; &quot; (line : &quot; &amp; Erl &amp; &quot;)&quot;
    Exit Sub    
End Sub

Sub LoadLibrary(LibraryName As String)
    If not DialogLibraries.islibraryloaded(LibraryName) then 
      DialogLibraries.LoadLibrary(LibraryName)
    End If
End Sub

Sub InitializeListboxProcedures(SourceListbox as Object, TargetListbox as Object)
  OriginalList()= ListBoxToStringList(SourceListbox)
  ClearListBox(TargetListbox)
End Sub

Sub pnlTablesOnFocus
  InitializeOriginalList(FieldNames())
End Sub

Sub pnlSheetsOnFocus
  InitializeOriginalList(ColumnNames())
End Sub

Sub cbxUseRangeOnChange
  if (cbxUseRange.State = 0) then
    ToggleControlsByState(cbxUseRange.State)
  else  
    ToggleListboxControls(Dlg, True)
  end if  
End Sub

Sub ToggleControlsByState(AState As Integer)
  if (cbxUseRange.State = 0) then
    edtSkipRows.Enable = AState 
    lstColumnNames.Enable = AState 
    btnRemoveAllColumns.Enable = AState
    btnRemoveSelColumns.Enable = AState
    btnMoveAllColumns.Enable = AState
    btnMoveSelColumns.Enable = AState
  end if  
End Sub

Sub cmbTableNamesOnChange
  Tablename = GetSelectedItem(cmbTableNames)
  ClearListBox(lstTableFields)
  
  Select Case Dlg.Model.Step
  Case _Tables
    FieldNames() = GetFieldNames(Db, Tablename)
  Case _Procedures
    InParams() = GetProceduresParams(Db, Tablename, _Input)
    OutParams() = GetProceduresParams(Db, Tablename, _Output)
    FillListBox(lstTableFields, InParams())
    AddMultiItemsToListBox(lstTableFields, OutParams())
    FieldNames() = lstTableFields.getItems()
  End Select
 
  FillListBox(lstTableFields, FieldNames())
  InitializeListboxProcedures(lstTableFields, lstSelTableFields)
  ToggleListboxControls(Dlg, True)  
End Sub

Sub cmbOperatesOnChange
  Operate = GetSelectedItem(cmbOperates)
  if (Operate = &quot;SELECT&quot;) then
    ParamTypeStr = GetParamTypeStr(_Output)
  elseif (Operate = &quot;INSERT&quot;) then
    ParamTypeStr = GetParamTypeStr(_Input)
  elseif (Operate = &quot;UPDATE&quot;) then
    ParamTypeStr = GetParamTypeStr(_Input)
  elseif (Operate = &quot;DELETE&quot;) then
    ParamTypeStr = &quot;&quot;
  end if  
  FieldNames = GetFieldNames(Db, Tablename)
  FillListBox(lstTableFields, FieldNames())
  InitializeListboxProcedures(lstTableFields, lstSelTableFields)
  ToggleListboxControls(Dlg, True)  
End Sub

Sub cmbColumnsOnChange
Dim SelColumn As String
Dim ColIndex, Count, SelIndex As Integer
Dim vColumnNames() As String

  pnlSheetsOnFocus
  SelColumn = GetSelectedItem(cmbColumns)

  if (SelColumn &lt;&gt; &quot;&quot;) then
    UpdNumberingListBox(lstSelColumnNames, false)
    SelColumnNames() = lstSelColumnNames.getItems()
    vColumnNames() = lstColumnNames.getItems()
    ColIndex = GetFindIndex(SelColumn, vColumnNames())
    if (ColIndex &gt;= 0) then
      SetNewSelection(lstColumnNames, ColIndex)
      MoveSelectedListBox(lstColumnNames, lstSelColumnNames)
    else
      AddValueToListBox(lstSelColumnNames, SelColumn)
      ColIndex = Ubound(SelColumnNames())
      SetNewSelection(lstSelColumnNames, ColIndex)
    end if
    SelIndex = lstSelColumnNames.getSelectedItemPos()
    if (SelIndex &lt; 0) then
      lstSelColumnNames.selectItemPos(0, true)
    end if  
    ToggleListboxControls(Dlg, True)  
    UpdNumberingListBox(lstSelColumnNames, true)
  end if  
  cmbColumns.Model.Text = &quot;&quot;
End Sub

Sub lstTableNamesOnChange
