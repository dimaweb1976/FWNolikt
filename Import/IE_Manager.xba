Sub btnMoveAllColumnsOnClick
Dim SelIndex As Integer
  UpdNumberingListBox(lstSelColumnNames, false)
  pnlSheetsOnFocus
  CopyListboxItems(lstColumnNames, lstSelColumnNames)
  SelIndex = lstSelColumnNames.getSelectedItemPos()
  if (SelIndex &lt; 0) then
    lstSelColumnNames.selectItemPos(ubound(lstSelColumnNames.getItems()), true)
  end if  
  ToggleListboxControls(Dlg, True)
  UpdNumberingListBox(lstSelColumnNames, true)
End Sub

Sub btnMoveSelColumnsOnClick
Dim SelIndex As Integer
  UpdNumberingListBox(lstSelColumnNames, false)
  pnlSheetsOnFocus
  MoveSelectedListBox(lstColumnNames, lstSelColumnNames)
  SelIndex = lstSelColumnNames.getSelectedItemPos()
  if (SelIndex &lt; 0) then
    lstSelColumnNames.selectItemPos(0, true)
  end if  
  ToggleListboxControls(Dlg, True)
  UpdNumberingListBox(lstSelColumnNames, true)
End Sub

Sub btnRemoveAllColumnsOnClick
  pnlSheetsOnFocus
  CopyListboxItems(lstSelColumnNames, lstColumnNames)
  ToggleListboxControls(Dlg, True)
End Sub

Sub btnRemoveSelColumnsOnClick
Dim SelIndex, Count As Integer
Dim SelColumn As String
  UpdNumberingListBox(lstSelColumnNames, false)
  pnlSheetsOnFocus
  SelColumn = lstSelColumnNames.getSelectedItem()
  Count = GetCountItems(lstSelColumnNames, SelColumn)
  if (Count = 1) then
    MoveOrderedSelectedListbox(lstColumnNames, lstSelColumnNames, False)
  elseif (Count &gt; 1) then 
    SelIndex = lstSelColumnNames.getSelectedItemPos()
    lstSelColumnNames.removeItems(SelIndex, 1)
    if (SelIndex &gt; 0) then
      lstSelColumnNames.selectItemPos(SelIndex - 1, true)
    elseif (SelIndex = 0) then
      lstSelColumnNames.selectItemPos(SelIndex, true)
    end if  
  end if
  ToggleListboxControls(Dlg, True)
  UpdNumberingListBox(lstSelColumnNames, true)
End Sub

Sub btnColumnUpOnClick
  UpdNumberingListBox(lstSelColumnNames, false)
